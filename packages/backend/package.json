{
  "name": "epds",
  "version": "0.0.1",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node --env-file=.env dist/index.js",
    "start:cluster": "tsc && node --env-file=.env dist/cluster.js",
    "start:no-full-sync": "tsc && node --env-file=.env dist/index.js --no-full-sync",
    "test": "tsc && node --env-file=.env --test dist",
    "migrate": "tsc && node --env-file=.env dist/db/cli.js migrate",
    "migration:generate": "tsc && typeorm-ts-node-commonjs migration:generate -d dist/db/dataSource.js",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "build:watch": "tsc --watch",
    "dev": "pnpm run build && concurrently \"pnpm run build:watch\" \"nodemon --watch dist --watch ../shared/dist -e js,json --delay 2 --exec 'node --env-file=.env dist/index.js'\""
  },
  "keywords": [],
  "author": "kugichka",
  "license": "WTFPL",
  "description": "experimental pissykaka database syncer",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@types/node": "^26.1.1",
    "@umechan/shared": "workspace:*",
    "axios": "^1.18.1",
    "better-sqlite3": "12.0.0",
    "fastify": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.1.0",
    "typescript": "6.0.2"
  }
}